#include <stdio.h>
int main(){
    float a , b, c , d , e , sum , percentage , TT;
     printf("Enter maximum marks as a whole \n");
    scanf("%f" , & TT);
    
    printf("Enter marks of five subjects: \n");
    scanf("%f %f %f %f %f ", &a , &b , &c , &d , &e  );
    
    sum = a + b + c + d + e;
    percentage = (sum / TT)* 100;
    
    if ( percentage >= 90){
        printf(" Grade A ");
    }
    else if (percentage >=80)
        {
            printf( " Grade B ");
            }
    else if(percentage >= 70 )
    {
        printf("Grade C ");
    }
    else if  (percentage >= 60)
    {
          printf(" Grade D ");
         }
    else {
        printf("FAIL");
    }
    return 0;
}
